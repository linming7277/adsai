# 预发环境集成测试配置
# 复制此文件为 .env.integration 并填写实际密码

# Supabase 数据库配置（预发环境）
SUPABASE_URL=https://jzzvizacfyipzdyiqfzb.supabase.co
SUPABASE_DB_URL=postgres://postgres.jzzvizacfyipzdyiqfzb:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_SERVICE_KEY=<从 Secret Manager 获取>

# Cloud Run 服务 URL（预发环境）
BILLING_URL=https://billing-preview-644672509127.asia-northeast1.run.app
OFFER_URL=https://offer-preview-644672509127.asia-northeast1.run.app
ADSCENTER_URL=https://adscenter-preview-644672509127.asia-northeast1.run.app
SITERANK_URL=https://siterank-preview-yt54xvsg5q-an.a.run.app
BROWSER_EXEC_URL=https://browser-exec-preview-yt54xvsg5q-an.a.run.app
RECOMMENDATIONS_URL=https://recommendations-preview-yt54xvsg5q-an.a.run.app
PROXY_POOL_URL=https://proxy-pool-preview-yt54xvsg5q-an.a.run.app

# 测试用户配置
TEST_USER_ID=test-user-integration
TEST_USER_EMAIL=test@integration.test
TEST_USER_TOKEN=<从预发环境获取>

# Cloud SQL 数据库配置（微服务专用）
CLOUD_SQL_HOST=<VPC内网地址>
CLOUD_SQL_DB=autoads_db
CLOUD_SQL_USER=postgres
CLOUD_SQL_PASSWORD=<从 Secret Manager 获取>

# 获取密码的命令：
# gcloud secrets versions access latest --secret="SUPABASE_SERVICE_KEY" --project=gen-lang-client-0944935873
