# 测试环境配置示例
# 复制此文件为 .env.test.local 并填入实际值

# === 推荐：直接使用 Cloud SQL ===
# GCP 认证（确保此文件存在且有效）
GOOGLE_APPLICATION_CREDENTIALS=secrets/gcp_codex_dev.json

# Cloud SQL 数据库（通过 VPC Connector 或 Cloud SQL Proxy）
# 实例: autoads, 数据库: autoads_db
# 注意：请替换 REPLACE_USER 和 REPLACE_PASSWORD 为实际凭据
TEST_DATABASE_URL=postgresql://REPLACE_USER:REPLACE_PASSWORD@localhost:5432/autoads_db?sslmode=disable

# === 备选：本地 Docker 测试数据库 ===
# 使用 scripts/start-test-db.sh 启动本地测试数据库
# TEST_DATABASE_URL=postgresql://test:test@localhost:5433/autoads_test?sslmode=disable
# TEST_REDIS_URL=redis://localhost:6380/0

# 测试模式
TEST_MODE=integration

# Node 环境
NODE_ENV=test

# 日志级别（error 减少测试输出噪音）
LOG_LEVEL=error

# 测试超时
TEST_TIMEOUT=30s

# 如果测试涉及认证，需要设置（使用测试专用密钥）
# AUTH_SECRET=test-secret-key-min-32-chars-long

# 如果测试需要调用后端服务
# BACKEND_URL=http://localhost:8080

# 如果测试需要 Redis
# TEST_REDIS_URL=redis://localhost:6379/0

# 测试数据库连接池配置（可选）
# DB_MAX_CONNECTIONS=5
# DB_MIN_CONNECTIONS=1
# DB_CONNECTION_TIMEOUT=5000

# 禁用外部服务调用（测试时使用 mock）
# DISABLE_EXTERNAL_CALLS=true
