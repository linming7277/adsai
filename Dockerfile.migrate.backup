# Cloud SQL Proxy Migration Tool
# AutoAds Database Migration using golang-migrate with Unix Socket

FROM golang:1.25-alpine AS builder

# Install golang-migrate
RUN apk add --no-cache curl && \
    curl -L https://github.com/golang-migrate/migrate/releases/download/v4.18.1/migrate.linux-amd64.tar.gz | tar -xz && \
    mv migrate /usr/local/bin/migrate

# Set working directory
WORKDIR /app

# Copy migration context from build stage
COPY . .

# Default command
CMD ["migrate", "-path", "/app/migrations", "-database", "${DATABASE_URL}", "version"]