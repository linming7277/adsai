'use client';

import React, { useState } from 'react';
import dynamic from 'next/dynamic';
import { PageLayout } from '~/core/ui/PageLayout';
import { useSmartBreadcrumb } from '../navigation/BreadcrumbNavigation';

// 动态导入组件以减少bundle大小
const ModalSystem = dynamic(
  () => import('../modals/ModalSystem').then(mod => ({ default: mod })),
  { ssr: false }
);

const NotificationSystem = dynamic(
  () => import('../notifications/NotificationSystem').then(mod => ({ default: mod })),
  { ssr: false }
);

const LoadingStates = dynamic(
  () => import('../loading/LoadingStates').then(mod => ({ default: mod })),
  { ssr: false }
);

const BreadcrumbNavigation = dynamic(
  () => import('../navigation/BreadcrumbNavigation').then(mod => ({ default: mod })),
  { ssr: false }
);

const Tabs = dynamic(
  () => import('~/core/ui/tabs').then(mod => ({ Tabs: mod.Tabs })),
  { ssr: false }
);

// 动态导入UIShowcase组件
const UIShowcaseMain = dynamic(
  () => import('./UIShowcaseMain').then(mod => ({ default: mod.UIShowcaseMain })),
  { ssr: false }
);

const UIShowcaseDemos = dynamic(
  () => import('./UIShowcaseDemos').then(mod => ({ default: mod.UIShowcaseDemos })),
  { ssr: false }
);

export default function UIShowcase() {
  const [activeTab, setActiveTab] = useState('overview');
  const [currentPath, setCurrentPath] = useState('/ui/showcase');
  const { breadcrumbs } = useSmartBreadcrumb(currentPath);

  const demoBreadcrumbItems = [
    { id: '1', label: '首页', href: '/', icon: <HomeIcon className="w-4 h-4" /> },
    { id: '2', label: '产品管理', href: '/products', icon: <CubeIcon className="w-4 h-4" /> },
    { id: '3', label: '电子产品', href: '/products/electronics', icon: <BoltIcon className="w-4 h-4" /> },
    { id: '4', label: '手机详情', href: '/products/electronics/phone-123', isActive: true }
  ];

  const handleModalDemo = (type: string) => {
    switch (type) {
      case 'info':
        openModal('info-modal', (
          <Modal
            isOpen={true}
            onClose={() => closeModal('info-modal')}
            type="info"
            title="信息提示"
            description="这是一个信息提示模态框示例。"
          >
            <p className="text-gray-700">模态框支持多种类型，包括信息、成功、警告、错误等。</p>
          </Modal>
        ));
        break;

      case 'confirm':
        openModal('confirm-modal', (
          <ConfirmModal
            isOpen={true}
            onClose={() => closeModal('confirm-modal')}
            type="question"
            title="确认操作"
            message="您确定要执行此操作吗？此操作无法撤销。"
            confirmText="确认"
            cancelText="取消"
            onConfirm={() => {
              success('操作已成功执行！');
              closeModal('confirm-modal');
            }}
          />
        ));
        break;

      case 'image':
        openModal('image-modal', (
          <ImagePreviewModal
            isOpen={true}
            onClose={() => closeModal('image-modal')}
            images={demoImages}
            initialIndex={0}
            allowDownload={true}
          />
        ));
        break;

      case 'drawer':
        openModal('drawer-modal', (
          <Drawer
            isOpen={true}
            onClose={() => closeModal('drawer-modal')}
            position="right"
            size="md"
            title="侧边栏抽屉"
          >
            <div className="space-y-4">
              <p className="text-gray-700">这是一个侧边栏抽屉示例。</p>
              <div className="space-y-3">
                <div className="p-3 bg-gray-50 rounded-lg">
                  <h4 className="font-medium">设置选项</h4>
                  <p className="text-sm text-gray-600">在这里可以配置各种设置。</p>
                </div>
                <div className="p-3 bg-gray-50 rounded-lg">
                  <h4 className="font-medium">用户信息</h4>
                  <p className="text-sm text-gray-600">显示和管理用户信息。</p>
                </div>
                <div className="p-3 bg-gray-50 rounded-lg">
                  <h4 className="font-medium">帮助文档</h4>
                  <p className="text-sm text-gray-600">查看帮助文档和使用指南。</p>
                </div>
              </div>
            </div>
          </Drawer>
        ));
        break;
