    let progress = 0;
    const interval = setInterval(() => {
      progress += Math.random() * 20;
      if (progress >= 100) {
        progress = 100;
        clearInterval(interval);
        completeProgress(progressId, 'success', '文件上传完成！');
      } else {
        updateProgress(progressId, progress, {
          message: `上传进度: ${Math.round(progress)}%`
        });
      }
    }, 500);
