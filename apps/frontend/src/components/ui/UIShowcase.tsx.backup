                  <div>
                    <h4 className="font-medium text-gray-900 mb-3">智能面包屑（自动生成）</h4>
                    <div className="mb-4">
                      <input
                        type="text"
                        value={currentPath}
                        onChange={(e) => setCurrentPath(e.target.value)}
                        placeholder="输入路径（如：/dashboard/analytics/reports）"
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                      />
                    </div>
                    <BreadcrumbNavigation items={breadcrumbs} />
                  </div>

                  {/* 路径历史演示 */}
                  <div>
                    <h4 className="font-medium text-gray-900 mb-3">路径历史</h4>
                    <div className="bg-gray-50 p-4 rounded-lg">
                      <p className="text-sm text-gray-600 mb-3">
                        路径历史功能会在用户浏览页面时自动记录访问路径，支持前进和后退操作。
                      </p>
                      <div className="flex gap-2">
                        <button className="px-3 py-1 bg-blue-100 text-blue-700 rounded text-sm">
                          模拟前进
                        </button>
                        <button className="px-3 py-1 bg-gray-100 text-gray-700 rounded text-sm">
                          模拟后退
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </TabsContent>
          </Tabs>
        </motion.div>

        {/* 技术特性 */}
        <motion.div
          className="grid grid-cols-1 md:grid-cols-2 gap-6"
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.6 }}
        >
          <div className="bg-gray-50 rounded-lg p-6 border border-gray-200">
            <h3 className="text-lg font-semibold text-gray-900 mb-4">组件特性</h3>
            <div className="space-y-3">
              <div className="flex items-center gap-3">
                <SparklesIcon className="w-5 h-5 text-blue-600" />
                <div>
                  <div className="font-medium text-gray-900">完全类型安全</div>
                  <div className="text-sm text-gray-600">TypeScript完整支持</div>
                </div>
              </div>
              <div className="flex items-center gap-3">
                <ShieldCheckIcon className="w-5 h-5 text-green-600" />
                <div>
                  <div className="font-medium text-gray-900">可访问性优先</div>
                  <div className="text-sm text-gray-600">WCAG 2.1 AA标准</div>
                </div>
              </div>
              <div className="flex items-center gap-3">
                <BoltIcon className="w-5 h-5 text-purple-600" />
                <div>
                  <div className="font-medium text-gray-900">高性能动画</div>
                  <div className="text-sm text-gray-600">Framer Motion优化</div>
                </div>
              </div>
            </div>
          </div>

          <div className="bg-gray-50 rounded-lg p-6 border border-gray-200">
            <h3 className="text-lg font-semibold text-gray-900 mb-4">设计原则</h3>
            <div className="space-y-3">
              <div className="flex items-center gap-3">
                <EyeIcon className="w-5 h-5 text-blue-600" />
                <div>
                  <div className="font-medium text-gray-900">用户体验优先</div>
                  <div className="text-sm text-gray-600">直观易用的交互</div>
                </div>
              </div>
              <div className="flex items-center gap-3">
                <ArrowRightIcon className="w-5 h-5 text-green-600" />
                <div>
                  <div className="font-medium text-gray-900">一致性设计</div>
                  <div className="text-sm text-gray-600">统一的视觉风格</div>
                </div>
              </div>
              <div className="flex items-center gap-3">
                <CogIcon className="w-5 h-5 text-purple-600" />
                <div>
                  <div className="font-medium text-gray-900">高度可定制</div>
                  <div className="text-sm text-gray-600">灵活的配置选项</div>
                </div>
              </div>
            </div>
          </div>
        </motion.div>

        {/* 模态框渲染器 */}
        <ModalRenderer />
      </div>
    </PageLayout>
  );
}