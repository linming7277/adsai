{
  "dashboard": {
    "title": "AutoAds - Ad Performance Dashboard",
    "tags": ["autoads", "adscenter", "performance"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "1m",
    "panels": [
      {
        "id": 1,
        "title": "Global Click-Through Rate (CTR)",
        "type": "singlestat",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "refId": "A",
            "queryType": "metrics",
            "metricQuery": {
              "query": "fetch cloud_run_revision | { metric 'prometheus.googleapis.com/autoads_adscenter_ad_clicks_total/counter' ; metric 'prometheus.googleapis.com/autoads_adscenter_ad_impressions_total/counter' } | ratio | group_by [], [value: aggregate(value)]"
            }
          }
        ],
        "format": "percentunit",
        "thresholds": "0.01,0.03",
        "colors": ["#d44a3a", "#e0b400", "#299c46"]
      },
      {
        "id": 2,
        "title": "Global Conversion Rate (CVR)",
        "type": "singlestat",
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "refId": "A",
            "queryType": "metrics",
            "metricQuery": {
              "query": "fetch cloud_run_revision | { metric 'prometheus.googleapis.com/autoads_adscenter_ad_conversions_total/counter' ; metric 'prometheus.googleapis.com/autoads_adscenter_ad_clicks_total/counter' } | ratio | group_by [], [value: aggregate(value)]"
            }
          }
        ],
        "format": "percentunit",
        "thresholds": "0.02,0.05",
        "colors": ["#d44a3a", "#e0b400", "#299c46"]
      },
      {
        "id": 3,
        "title": "Total Ad Impressions",
        "type": "singlestat",
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "refId": "A",
            "queryType": "metrics",
            "metricQuery": {
              "query": "fetch cloud_run_revision | metric 'prometheus.googleapis.com/autoads_adscenter_ad_impressions_total/counter' | group_by [], [value: aggregate(value.autoads_adscenter_ad_impressions_total)]"
            }
          }
        ],
        "format": "short"
      },
      {
        "id": 4,
        "title": "Active Ads",
        "type": "singlestat",
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "refId": "A",
            "queryType": "metrics",
            "metricQuery": {
              "query": "fetch cloud_run_revision | metric 'prometheus.googleapis.com/autoads_adscenter_ads_active/gauge' | group_by [], [value: aggregate(value.autoads_adscenter_ads_active)]"
            }
          }
        ],
        "format": "short"
      },
      {
        "id": 5,
        "title": "CTR by Platform",
        "type": "graph",
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
        "targets": [
          {
            "refId": "A",
            "queryType": "metrics",
            "metricQuery": {
              "query": "fetch cloud_run_revision | { metric 'prometheus.googleapis.com/autoads_adscenter_ad_clicks_total/counter' ; metric 'prometheus.googleapis.com/autoads_adscenter_ad_impressions_total/counter' } | ratio | group_by 1m, [platform], [value: aggregate(value)] | every 1m"
            }
          }
        ],
        "yaxes": [
          {"label": "CTR", "format": "percentunit"},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "Impressions by Platform",
        "type": "graph",
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
        "targets": [
          {
            "refId": "A",
            "queryType": "metrics",
            "metricQuery": {
              "query": "fetch cloud_run_revision | metric 'prometheus.googleapis.com/autoads_adscenter_ad_impressions_total/counter' | group_by 1m, [platform], [value: aggregate(value.autoads_adscenter_ad_impressions_total)] | every 1m"
            }
          }
        ]
      },
      {
        "id": 7,
        "title": "Top 10 Campaigns by CTR",
        "type": "table",
        "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
        "targets": [
          {
            "refId": "A",
            "queryType": "metrics",
            "metricQuery": {
              "query": "fetch cloud_run_revision | { metric 'prometheus.googleapis.com/autoads_adscenter_ad_clicks_total/counter' ; metric 'prometheus.googleapis.com/autoads_adscenter_ad_impressions_total/counter' } | ratio | group_by 1m, [campaign_id], [value: aggregate(value)] | every 1m | top 10"
            }
          }
        ]
      },
      {
        "id": 8,
        "title": "Platform Distribution (Impressions)",
        "type": "piechart",
        "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
        "targets": [
          {
            "refId": "A",
            "queryType": "metrics",
            "metricQuery": {
              "query": "fetch cloud_run_revision | metric 'prometheus.googleapis.com/autoads_adscenter_ad_impressions_total/counter' | group_by [platform], [value: aggregate(value.autoads_adscenter_ad_impressions_total)]"
            }
          }
        ]
      },
      {
        "id": 9,
        "title": "Cost Per Click (CPC) by Platform",
        "type": "graph",
        "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
        "targets": [
          {
            "refId": "A",
            "queryType": "metrics",
            "metricQuery": {
              "query": "fetch cloud_run_revision | { metric 'prometheus.googleapis.com/autoads_adscenter_ad_spend_total/counter' ; metric 'prometheus.googleapis.com/autoads_adscenter_ad_clicks_total/counter' } | ratio | group_by 1m, [platform], [value: aggregate(value)] | every 1m"
            }
          }
        ],
        "yaxes": [
          {"label": "CPC (cents)", "format": "short"},
          {"format": "short"}
        ]
      },
      {
        "id": 10,
        "title": "Total Ad Spend by Platform",
        "type": "graph",
        "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
        "targets": [
          {
            "refId": "A",
            "queryType": "metrics",
            "metricQuery": {
              "query": "fetch cloud_run_revision | metric 'prometheus.googleapis.com/autoads_adscenter_ad_spend_total/counter' | group_by 1m, [platform], [value: aggregate(value.autoads_adscenter_ad_spend_total)] | every 1m"
            }
          }
        ],
        "yaxes": [
          {"label": "Spend (cents)", "format": "short"},
          {"format": "short"}
        ]
      }
    ]
  },
  "overwrite": true
}
