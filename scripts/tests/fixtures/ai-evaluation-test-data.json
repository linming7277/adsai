      "plan": "starter",
      "initialTokens": 100,
      "canUseAI": false
    },
    "professional": {
      "email": "test-pro@adsai.dev",
      "password": "Test1234!",
      "plan": "professional",
      "initialTokens": 500,
      "canUseAI": true
    },
    "elite": {
      "email": "test-elite@adsai.dev",
      "password": "Test1234!",
      "plan": "elite",
      "initialTokens": 1000,
