    "realWorldExamples": {
      "amazon": {
        "name": "Amazon.com",
        "url": "https://www.amazon.com",
        "expectedGrade": "A",
        "notes": "最高流量电商平台，几乎总是A级"
      },
      "walmart": {
        "name": "Walmart",
        "url": "https://www.walmart.com",
        "expectedGrade": "A",
        "notes": "大型零售商，高流量高转化"
      },
      "target": {
        "name": "Target",
        "url": "https://www.target.com",
        "expectedGrade": "A",
        "notes": "美国主流零售，稳定A级"
      },
      "bestbuy": {
        "name": "Best Buy",
        "url": "https://www.bestbuy.com",
        "expectedGrade": "B",
        "notes": "电子产品垂直领域，B级"
      },
      "etsy": {
        "name": "Etsy",
        "url": "https://www.etsy.com",
        "expectedGrade": "B",
        "notes": "手工艺品平台，B级"
      }
    }
  },

  "apiEndpoints": {
    "offerService": {
      "baseURL": "${OFFER_SERVICE_URL}",
      "endpoints": {
        "evaluate": "POST /api/v1/offers/{offerId}/evaluate",
        "getLatest": "GET /api/v1/offers/{offerId}/evaluations/latest",
        "getList": "GET /api/v1/offers/{offerId}/evaluations"
      }
    },
    "billingService": {
      "baseURL": "${BILLING_SERVICE_URL}",
      "endpoints": {
        "reserve": "POST /api/v1/tokens/reserve",
        "consume": "POST /api/v1/tokens/consume",
        "release": "POST /api/v1/tokens/release",
        "balance": "GET /api/v1/users/me/tokens/balance",
        "subscription": "GET /api/v1/users/me/subscription"
      }
    },
    "siterankService": {
      "baseURL": "${SITERANK_SERVICE_URL}",
      "endpoints": {
        "evaluate": "POST /api/v1/offers/{offerId}/evaluate"
      }
    }
  },

  "databaseValidation": {
    "tables": {
      "offer_evaluations": {
        "requiredFields": [
          "evaluation_id",
          "offer_id",
          "status",
          "evaluation_type",
          "tokens_consumed",
          "ai_recommendation_score",
          "ai_recommendation",
          "similarweb_score",
          "created_at",
          "completed_at"
        ],
        "constraints": {
          "evaluation_type": ["basic", "ai_enhanced"],
          "status": ["pending", "processing", "completed", "failed"],
          "tokens_consumed": [1, 3],
          "ai_recommendation_score": { "min": 0, "max": 100 }
        }
      },
      "evaluation_aggregations": {
        "requiredFields": [
          "url_hash",
          "offer_url",
          "brand_name",
          "evaluation_count",
          "latest_evaluation_id",
          "latest_score",
          "cache_valid_until"
        ],
        "constraints": {
          "evaluation_count": { "min": 1 },
          "cache_valid_until": "NOW() + INTERVAL '7 days'"
        }
      },
      "similarweb_global_cache": {
        "requiredFields": [
          "domain",
          "data",
          "status",
          "cached_at",
          "expires_at"
        ],
        "constraints": {
          "status": ["success", "failed"],
          "expires_at": "NOW() + INTERVAL '7 days' | NOW() + INTERVAL '1 hour'"
        }
      },
      "token_transactions": {
        "requiredFields": [
          "transaction_id",
          "user_id",
          "amount",
          "transaction_type",
          "service",
          "action",
          "created_at"
        ],
        "constraints": {
          "transaction_type": ["debit", "credit"],
          "service": ["offer"],
          "action": ["evaluate"]
        }
      }
    }
  },

  "performanceThresholds": {
    "aiEvaluationTime": {
      "max": 30000,
      "unit": "ms",
      "description": "AI评估完成时间应小于30秒"
    },
    "componentRenderTime": {
      "max": 500,
      "unit": "ms",
      "description": "前端组件渲染时间应小于500ms"
    },
    "apiResponseTime": {
      "max": 2000,
      "unit": "ms",
      "description": "API响应时间应小于2秒"
    },
    "pollingInterval": {
      "expected": 3000,
      "tolerance": 500,
      "unit": "ms",
      "description": "状态轮询间隔应为3秒±500ms"
    },
    "tokenDeductionDelay": {
      "max": 1000,
      "unit": "ms",
      "description": "Token扣除延迟应小于1秒"
    }
  },

  "errorScenarios": {
    "insufficientTokens": {
      "description": "Token余额不足",
      "expectedBehavior": "禁用评估按钮 + 显示错误提示",
      "expectedUI": "按钮disabled，Toast通知"
    },
    "apiTimeout": {
      "description": "API请求超时",
      "expectedBehavior": "显示超时错误，提示重试",
      "expectedUI": "Toast通知 + 错误详情"
    },
    "similarWebUnavailable": {
      "description": "SimilarWeb数据不可用",
      "expectedBehavior": "降级到基础评估",
      "expectedStatus": "completed",
      "expectedFields": { "similarWebScore": null }
    },
    "geminiAPIFailure": {
      "description": "Gemini API调用失败",
      "expectedBehavior": "重试3次后记录错误",
      "expectedStatus": "failed",
      "expectedFields": { "errorMessage": "AI evaluation failed after 3 retries" }
    },
    "networkDisconnect": {
      "description": "网络连接断开",
      "expectedBehavior": "暂停轮询，重连后恢复",
      "expectedUI": "网络错误提示"
    }
  },

  "testExecutionConfig": {
    "browser": {
      "type": "chromium",
      "headless": false,
      "slowMo": 100,
      "viewport": { "width": 1920, "height": 1080 }
    },
    "timeouts": {
      "test": 180000,
      "navigation": 30000,
      "action": 10000
    },
    "retries": {
      "max": 2,
      "delay": 5000
    },
    "screenshots": {
      "onFailure": true,
      "path": "./test-results/screenshots"
    },
    "videos": {
      "enabled": false,
      "path": "./test-results/videos"
    }
  }
}
