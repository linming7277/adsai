      "expectedScore": {
        "min": 70,
        "max": 84,
        "grade": "B"
      },
      "expectedSimilarWebData": {
        "globalRank": 500,
        "monthlyVisits": 15000000,
        "bounceRate": 0.42,
        "avgVisitDuration": 180
      },
      "expectedAIInsights": {
        "industry": "E-commerce",
        "productType": "Beauty & Cosmetics",
        "recommendationReasons": [
          "垂直领域头部品牌",
