{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Evaluation Test Data",
  "description": "测试数据配置 - 不同评分段的Offer样本",
  "version": "1.0.0",
  "lastUpdated": "2025-10-16",

  "testUsers": {
    "starter": {
