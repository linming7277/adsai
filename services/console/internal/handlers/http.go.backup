// getTokenBalances returns a paginated list of user token balances
// GET /api/v1/console/tokens/balances?page=1&pageSize=20&search=user@example.com
func (h *Handler) getTokenBalances(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}

	ensureTokenTables(r.Context(), h.DB)

	// 解析查询参数
	page := 1
	if v := r.URL.Query().Get("page"); v != "" {
		if n, err := strconv.Atoi(v); err == nil && n > 0 {
			page = n
		}
	}

	pageSize := 20
	if v := r.URL.Query().Get("pageSize"); v != "" {
		if n, err := strconv.Atoi(v); err == nil && n > 0 && n <= 100 {
			pageSize = n
		}
	}

	search := strings.TrimSpace(r.URL.Query().Get("search"))
	offset := (page - 1) * pageSize

	// 查询用户余额
	var rows pgx.Rows
	var err error
	var totalCount int

	// 构建查询
	if search != "" {
		// 先查询总数
		searchPattern := "%" + search + "%"
		err = h.DB.QueryRow(r.Context(), `
            SELECT COUNT(*)
            FROM "UserToken" ut
            LEFT JOIN "User" u ON u.id = ut."userId"
            WHERE ut."userId" ILIKE $1 OR u.email ILIKE $1
        `, searchPattern).Scan(&totalCount)
		if err != nil {
			errors.Write(w, r, http.StatusInternalServerError, "QUERY_ERROR", "Failed to count balances", map[string]string{"error": err.Error()})
			return
		}

		// 查询数据
		rows, err = h.DB.Query(r.Context(), `
            SELECT
                ut."userId",
                COALESCE(u.email, ''),
                ut.balance,
                0 as consumed,
                ut."updatedAt"
            FROM "UserToken" ut
            LEFT JOIN "User" u ON u.id = ut."userId"
            WHERE ut."userId" ILIKE $1 OR u.email ILIKE $1
            ORDER BY ut.balance DESC
            LIMIT $2 OFFSET $3
        `, searchPattern, pageSize, offset)
	} else {
		// 先查询总数
		err = h.DB.QueryRow(r.Context(), `SELECT COUNT(*) FROM "UserToken"`).Scan(&totalCount)
		if err != nil {
			errors.Write(w, r, http.StatusInternalServerError, "QUERY_ERROR", "Failed to count balances", map[string]string{"error": err.Error()})
			return
		}

		// 查询数据
		rows, err = h.DB.Query(r.Context(), `
            SELECT
                ut."userId",
                COALESCE(u.email, ''),
                ut.balance,
                0 as consumed,
                ut."updatedAt"
            FROM "UserToken" ut
            LEFT JOIN "User" u ON u.id = ut."userId"
            ORDER BY ut.balance DESC
            LIMIT $1 OFFSET $2
        `, pageSize, offset)
	}

	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "QUERY_ERROR", "Failed to query balances", map[string]string{"error": err.Error()})
		return
	}
	defer rows.Close()

	type UserBalance struct {
		UserID    string    `json:"userId"`
		Email     string    `json:"email,omitempty"`
		Balance   int64     `json:"balance"`
		Consumed  int64     `json:"consumed,omitempty"`
		UpdatedAt time.Time `json:"updatedAt"`
	}

	var balances []UserBalance
	for rows.Next() {
		var balance UserBalance
		if err := rows.Scan(&balance.UserID, &balance.Email, &balance.Balance, &balance.Consumed, &balance.UpdatedAt); err != nil {
			log.Printf("[console] scan balance row failed: %v", err)
			continue
		}
		balances = append(balances, balance)
	}

	if balances == nil {
		balances = []UserBalance{}
	}

	totalPages := (totalCount + pageSize - 1) / pageSize

	w.Header().Set("Content-Type", "application/json")
	_ = json.NewEncoder(w).Encode(map[string]interface{}{
		"balances":   balances,
		"totalPages": totalPages,
		"totalCount": totalCount,
	})
}

// topUpTokens adds tokens to a user's balance
// POST /api/v1/console/tokens/topup
// Body: {"userId": "user123", "amount": 1000, "reason": "Admin top-up"}
func (h *Handler) topUpTokens(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}

	ensureTokenTables(r.Context(), h.DB)

	type TopUpRequest struct {
		UserID string `json:"userId"`
		Amount int64  `json:"amount"`
		Reason string `json:"reason"`
	}

	var req TopUpRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		errors.Write(w, r, http.StatusBadRequest, "INVALID_JSON", "Invalid request body", nil)
		return
	}

	// 验证参数
	if req.UserID == "" {
		errors.Write(w, r, http.StatusBadRequest, "INVALID_ARGUMENT", "userId is required", nil)
		return
	}
	if req.Amount <= 0 {
		errors.Write(w, r, http.StatusBadRequest, "INVALID_ARGUMENT", "amount must be positive", nil)
		return
	}
	if req.Reason == "" {
		errors.Write(w, r, http.StatusBadRequest, "INVALID_ARGUMENT", "reason is required", nil)
		return
	}

	// 获取操作人信息（从context中）
	adminUserID, _ := auth.ExtractUserID(r)

	// 开启事务
	tx, err := h.DB.Begin(r.Context())
	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "TRANSACTION_ERROR", "Failed to start transaction", nil)
		return
	}
	defer tx.Rollback(r.Context())

	// 更新余额（如果用户不存在则创建）
	var newBalance int64
	err = tx.QueryRow(r.Context(), `
        INSERT INTO "UserToken" ("userId", balance, "updatedAt")
        VALUES ($1, $2, NOW())
        ON CONFLICT ("userId") DO UPDATE
        SET balance = "UserToken".balance + $2,
            "updatedAt" = NOW()
        RETURNING balance
    `, req.UserID, req.Amount).Scan(&newBalance)

	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "UPDATE_ERROR", "Failed to update balance", map[string]string{"error": err.Error()})
		return
	}

	// 记录交易日志
	_, err = tx.Exec(r.Context(), `
        INSERT INTO "TokenTransaction" ("userId", amount, reason, created_at)
        VALUES ($1, $2, $3, NOW())
    `, req.UserID, req.Amount, fmt.Sprintf("Admin top-up: %s (by %s)", req.Reason, adminUserID))

	if err != nil {
		log.Printf("[console] failed to record token transaction: %v", err)
		// 不阻止充值，只记录日志
	}

	// 提交事务
	if err := tx.Commit(r.Context()); err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "COMMIT_ERROR", "Failed to commit transaction", nil)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	_ = json.NewEncoder(w).Encode(map[string]interface{}{
		"success":    true,
		"newBalance": newBalance,
		"message":    fmt.Sprintf("Successfully added %d tokens", req.Amount),
	})
}

// getAPIUsage parses Prometheus metrics of a service and returns http_requests_total breakdown.
// GET /api/v1/console/api-usage?service=adscenter&base=<override_url>
// Response: { service, items:[{method,path,status,count}], totals:{all:int, byMethod:{GET:...,POST:...}} }
func (h *Handler) getAPIUsage(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	svc := strings.TrimSpace(r.URL.Query().Get("service"))
	if svc == "" {
		svc = "adscenter"
	}
	base := strings.TrimSpace(r.URL.Query().Get("base"))
	if base == "" {
		// env mapping similar to getSLO
		switch svc {
		case "adscenter":
			base = strings.TrimRight(os.Getenv("ADSCENTER_URL"), "/")
		case "siterank":
			base = strings.TrimRight(os.Getenv("SITERANK_URL"), "/")
		case "batchopen":
			base = strings.TrimRight(os.Getenv("BATCHOPEN_URL"), "/")
		case "billing":
			base = strings.TrimRight(os.Getenv("BILLING_URL"), "/")
		case "offer":
			base = strings.TrimRight(os.Getenv("OFFER_URL"), "/")
		case "notifications":
			base = strings.TrimRight(os.Getenv("NOTIFICATIONS_URL"), "/")
		}
	}
	if base == "" {
		errors.Write(w, r, http.StatusBadRequest, "INVALID_ARGUMENT", "service base url not configured", nil)
		return
	}
	ctx, cancel := context.WithTimeout(r.Context(), 1500*time.Millisecond)
	req, _ := http.NewRequestWithContext(ctx, http.MethodGet, base+"/metrics", nil)
	resp, err := httpx.New(1500 * time.Millisecond).DoRaw(req)
	cancel()
	if err != nil || resp == nil || resp.StatusCode != 200 {
		errors.Write(w, r, http.StatusBadGateway, "UPSTREAM_UNAVAILABLE", "fetch /metrics failed", map[string]string{"error": fmt.Sprintf("%v", err)})
		return
	}
	b, _ := io.ReadAll(io.LimitReader(resp.Body, 1<<20))
	_ = resp.Body.Close()
	// parse lines like: http_requests_total{service="adscenter",method="GET",path="/api/v1/...",status="OK"} 123
	type item struct {
		Method, Path, Status string
		Count                int64
	}
	items := []item{}
	byKey := map[string]*item{}
	// split lines
	lines := strings.Split(string(b), "\n")
	for _, ln := range lines {
		if !strings.HasPrefix(ln, "http_requests_total{") {
			continue
		}
		// quick filter by service label
		if !strings.Contains(ln, "service=\""+svc+"\"") {
			continue
		}
		// extract labels
		// method
		method := extractLabel(ln, "method")
		path := extractLabel(ln, "path")
		status := extractLabel(ln, "status")
		// count at the end
		fields := strings.Fields(ln)
		if len(fields) < 2 {
			continue
		}
		cntStr := fields[len(fields)-1]
		// handle trailing timestamps like "123 1696000000" if present
		if strings.Contains(cntStr, ".") && len(fields) >= 3 {
			cntStr = fields[len(fields)-2]
		}
		var count int64 = 0
		if v, err := strconv.ParseFloat(cntStr, 64); err == nil {
			count = int64(v)
		}
		k := method + "|" + path + "|" + status
		if it, ok := byKey[k]; ok {
			if count > it.Count {
				it.Count = count
			}
		} else {
			byKey[k] = &item{Method: method, Path: path, Status: status, Count: count}
		}
	}
	for _, it := range byKey {
		items = append(items, *it)
	}
	sort.Slice(items, func(i, j int) bool { return items[i].Count > items[j].Count })
	totals := map[string]any{}
	var all int64
	byMethod := map[string]int64{}
	for _, it := range items {
		all += it.Count
		byMethod[it.Method] += it.Count
	}
	totals["all"] = all
	totals["byMethod"] = byMethod
	out := map[string]any{"service": svc, "items": items, "totals": totals}
	w.Header().Set("Content-Type", "application/json")
	_ = json.NewEncoder(w).Encode(out)
}

// extractLabel finds label value like label="..." in a metrics line.
func extractLabel(line, label string) string {
	key := label + "=\""
	i := strings.Index(line, key)
	if i < 0 {
		return ""
	}
	i += len(key)
	j := strings.Index(line[i:], "\"")
	if j < 0 {
		return ""
	}
	return line[i : i+j]
}

// adscenterBusiness aggregates business metrics from Adscenter /metrics.
// GET /api/v1/console/adscenter/business?base=<override>
func (h *Handler) adscenterBusiness(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	base := strings.TrimSpace(r.URL.Query().Get("base"))
	if base == "" {
		base = strings.TrimRight(os.Getenv("ADSCENTER_URL"), "/")
	}
	if base == "" {
		errors.Write(w, r, http.StatusBadRequest, "SERVER_NOT_CONFIGURED", "ADSCENTER_URL not set", nil)
		return
	}
	ctx, cancel := context.WithTimeout(r.Context(), 2*time.Second)
	defer cancel()
	req, _ := http.NewRequestWithContext(ctx, http.MethodGet, base+"/metrics", nil)
	resp, err := httpx.New(2 * time.Second).DoRaw(req)
	if err != nil || resp == nil || resp.StatusCode != 200 {
		errors.Write(w, r, http.StatusBadGateway, "UPSTREAM_UNAVAILABLE", "fetch /metrics failed", map[string]string{"error": fmt.Sprintf("%v", err)})
		return
	}
	b, _ := io.ReadAll(io.LimitReader(resp.Body, 1<<20))
	_ = resp.Body.Close()
	lines := strings.Split(string(b), "\n")
	// Aggregations
	typeCount := map[string]int64{}
	errType := map[string]int64{}
	derivFilled := map[string]int64{}
	derivSkipped := map[string]int64{}
	// histogram sums
	latSum := map[string]float64{}
	latCnt := map[string]float64{}
	for _, ln := range lines {
		if strings.HasPrefix(ln, "#") || strings.TrimSpace(ln) == "" {
			continue
		}
		// ac_execute_action_total{type="ADJUST_CPC"}
		if strings.HasPrefix(ln, "ac_execute_action_total") {
			t := extractLabel(ln, "type")
			if t == "" {
				continue
			}
			fields := strings.Fields(ln)
			if len(fields) == 0 {
				continue
			}
			vStr := fields[len(fields)-1]
			if v, err := strconv.ParseFloat(vStr, 64); err == nil {
				typeCount[t] = int64(v)
			}
		} else if strings.HasPrefix(ln, "ac_execute_action_errors_total") {
			t := extractLabel(ln, "type")
			if t == "" {
				continue
			}
			fields := strings.Fields(ln)
			if len(fields) == 0 {
				continue
			}
			vStr := fields[len(fields)-1]
			if v, err := strconv.ParseFloat(vStr, 64); err == nil {
				errType[t] = int64(v)
			}
		} else if strings.HasPrefix(ln, "ac_derived_targets_total") {
			t := extractLabel(ln, "type")
			r := extractLabel(ln, "result")
			if t == "" || r == "" {
				continue
			}
			fields := strings.Fields(ln)
			if len(fields) == 0 {
				continue
			}
			vStr := fields[len(fields)-1]
			if v, err := strconv.ParseFloat(vStr, 64); err == nil {
				if r == "filled" {
					derivFilled[t] = int64(v)
				} else if r == "skipped" {
					derivSkipped[t] = int64(v)
				}
			}
		} else if strings.HasPrefix(ln, "ac_execute_action_latency_seconds_sum") {
			t := extractLabel(ln, "type")
			if t == "" {
				continue
			}
			fields := strings.Fields(ln)
			if len(fields) == 0 {
				continue
			}
			if v, err := strconv.ParseFloat(fields[len(fields)-1], 64); err == nil {
				latSum[t] = v
			}
		} else if strings.HasPrefix(ln, "ac_execute_action_latency_seconds_count") {
			t := extractLabel(ln, "type")
			if t == "" {
				continue
			}
			fields := strings.Fields(ln)
			if len(fields) == 0 {
				continue
			}
			if v, err := strconv.ParseFloat(fields[len(fields)-1], 64); err == nil {
				latCnt[t] = v
			}
		}
	}
	// Build output
	type metric struct {
		Total          int64   `json:"total"`
		Errors         int64   `json:"errors"`
		ErrorRate      float64 `json:"errorRate"`
		AvgLatencyMs   float64 `json:"avgLatencyMs"`
		DeriveFilled   int64   `json:"deriveFilled"`
		DeriveSkipped  int64   `json:"deriveSkipped"`
		DeriveSkipRate float64 `json:"deriveSkipRate"`
	}
	out := map[string]metric{}
	// union of types
	types := map[string]struct{}{}
	for k := range typeCount {
		types[k] = struct{}{}
	}
	for k := range errType {
		types[k] = struct{}{}
	}
	for k := range derivFilled {
		types[k] = struct{}{}
	}
	for k := range derivSkipped {
		types[k] = struct{}{}
	}
	for k := range types {
		tot := typeCount[k]
		er := errType[k]
		fill := derivFilled[k]
		skip := derivSkipped[k]
		rate := 0.0
		if tot > 0 {
			rate = float64(er) / float64(tot)
		}
		srate := 0.0
		if (fill + skip) > 0 {
			srate = float64(skip) / float64(fill+skip)
		}
		avg := 0.0
		if latCnt[k] > 0 {
			avg = (latSum[k] / latCnt[k]) * 1000.0
		}
		out[k] = metric{Total: tot, Errors: er, ErrorRate: rate, AvgLatencyMs: avg, DeriveFilled: fill, DeriveSkipped: skip, DeriveSkipRate: srate}
	}
	w.Header().Set("Content-Type", "application/json")
	_ = json.NewEncoder(w).Encode(map[string]any{"service": "adscenter", "types": out, "updatedAt": time.Now().UTC().Format(time.RFC3339)})
}

// roiAggregate aggregates ROI across offers from OfferDailyKPI within a time window.
// GET /api/v1/console/roi/aggregate?days=30&minRosc=1.2&q=keyword&page=1&size=50
func (h *Handler) roiAggregate(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	ctx := r.Context()
	// Parse params
	days := 30
	if v := strings.TrimSpace(r.URL.Query().Get("days")); v != "" {
		if n, e := strconv.Atoi(v); e == nil && n > 0 && n <= 365 {
			days = n
		}
	}
	minRosc := 0.0
	if v := strings.TrimSpace(r.URL.Query().Get("minRosc")); v != "" {
		if f, e := strconv.ParseFloat(v, 64); e == nil && f >= 0 {
			minRosc = f
		}
	}
	q := strings.TrimSpace(r.URL.Query().Get("q"))
	accountID := strings.TrimSpace(r.URL.Query().Get("accountId"))
	page, size := 1, 50
	if v := strings.TrimSpace(r.URL.Query().Get("page")); v != "" {
		if n, e := strconv.Atoi(v); e == nil && n > 0 {
			page = n
		}
	}
	if v := strings.TrimSpace(r.URL.Query().Get("size")); v != "" {
		if n, e := strconv.Atoi(v); e == nil && n > 0 && n <= 500 {
			size = n
		}
	}
	offset := (page - 1) * size

	// Aggregate across OfferDailyKPI joined with Offer for name
	// Note: Use date >= CURRENT_DATE - (days-1) to include today
	// Filters: minRosc (applied after SUM), q (ILIKE on name)
	// Compute summary in a separate query

	// Summary
	var sumImp, sumClk int64
	var sumSpend, sumRev float64
	err := h.DB.QueryRow(ctx, `
        SELECT COALESCE(SUM(k.impressions),0), COALESCE(SUM(k.clicks),0), COALESCE(SUM(k.spend),0), COALESCE(SUM(k.revenue),0)
        FROM "OfferDailyKPI" k
        WHERE k.date >= CURRENT_DATE - ($1::int - 1)
    `, days).Scan(&sumImp, &sumClk, &sumSpend, &sumRev)
	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "INTERNAL", "summary query failed", map[string]string{"error": err.Error()})
		return
	}
	summary := map[string]any{
		"impressions": sumImp,
		"clicks":      sumClk,
		"spend":       round2(sumSpend),
		"revenue":     round2(sumRev),
		"rosc": func() float64 {
			if sumSpend > 0 {
				return round2(sumRev / sumSpend)
			}
			return 0
		}(),
	}

	// Items with optional name filter, account filter and minRosc
	// Build dynamic WHERE for name filter; apply minRosc in HAVING
	nameFilter := "%"
	if q != "" {
		nameFilter = "%" + strings.ToLower(q) + "%"
	}

	// Query items
	qItems := `
        SELECT o.id, COALESCE(o.name,''),
               COALESCE(SUM(k.impressions),0) AS imp,
               COALESCE(SUM(k.clicks),0) AS clk,
               COALESCE(SUM(k.spend),0) AS spend,
               COALESCE(SUM(k.revenue),0) AS revenue
        FROM "OfferDailyKPI" k
        JOIN "Offer" o ON o.id = k.offer_id
        WHERE k.date >= CURRENT_DATE - ($1::int - 1)
          AND ( $2 = '%' OR LOWER(o.name) LIKE $2 )
    `
	args := []any{days, nameFilter}
	if accountID != "" {
		qItems += ` AND EXISTS (SELECT 1 FROM "OfferAccountMap" m WHERE m.offer_id = o.id AND m.account_id = $3)`
		args = append(args, accountID)
	}
	// complete
	// Note: adjust placeholders based on whether accountID used
	havingIdx := 3
	limitIdx := 4
	offIdx := 5
	if accountID != "" {
		havingIdx = 4
		limitIdx = 5
		offIdx = 6
	}
	qItems += fmt.Sprintf(`
        GROUP BY o.id, o.name
        HAVING (CASE WHEN COALESCE(SUM(k.spend),0) > 0 THEN COALESCE(SUM(k.revenue),0)/COALESCE(SUM(k.spend),0) ELSE 0 END) >= $%d
        ORDER BY (CASE WHEN COALESCE(SUM(k.spend),0) > 0 THEN COALESCE(SUM(k.revenue),0)/COALESCE(SUM(k.spend),0) ELSE 0 END) DESC, COALESCE(SUM(k.revenue),0) DESC
        LIMIT $%d OFFSET $%d`, havingIdx, limitIdx, offIdx)
	args = append(args, minRosc, size, offset)
	rows, err := h.DB.Query(ctx, qItems, args...)
	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "INTERNAL", "items query failed", map[string]string{"error": err.Error()})
		return
	}
	defer rows.Close()
	type item struct {
		OfferID, Name        string
		Impressions, Clicks  int64
		Spend, Revenue, ROSC float64
	}
	items := []item{}
	for rows.Next() {
		var it item
		if err := rows.Scan(&it.OfferID, &it.Name, &it.Impressions, &it.Clicks, &it.Spend, &it.Revenue); err != nil {
			continue
		}
		if it.Spend > 0 {
			it.ROSC = round2(it.Revenue / it.Spend)
		} else {
			it.ROSC = 0
		}
		it.Spend = round2(it.Spend)
		it.Revenue = round2(it.Revenue)
		items = append(items, it)
	}
	// Top accounts aggregation (optional, best-effort)
	topN := 20
	if v := strings.TrimSpace(r.URL.Query().Get("top")); v != "" {
		if n, e := strconv.Atoi(v); e == nil && n > 0 && n <= 100 {
			topN = n
		}
	}
	var topAccounts []map[string]any
	func() {
		qTop := `
            SELECT m.account_id,
                   COALESCE(SUM(k.spend),0) AS spend,
                   COALESCE(SUM(k.revenue),0) AS revenue
            FROM "OfferDailyKPI" k
            JOIN "OfferAccountMap" m ON m.offer_id = k.offer_id
            WHERE k.date >= CURRENT_DATE - ($1::int - 1)
            GROUP BY m.account_id
            ORDER BY COALESCE(SUM(k.revenue),0) DESC
            LIMIT $2`
		rr, er := h.DB.Query(ctx, qTop, days, topN)
		if er != nil {
			return
		}
		defer rr.Close()
		for rr.Next() {
			var acc string
			var sp, rv float64
			if er := rr.Scan(&acc, &sp, &rv); er != nil {
				continue
			}
			ro := 0.0
			if sp > 0 {
				ro = rv / sp
			}
			topAccounts = append(topAccounts, map[string]any{"accountId": acc, "spend": round2(sp), "revenue": round2(rv), "rosc": round2(ro)})
		}
	}()

	// Response
	w.Header().Set("Content-Type", "application/json")
	_ = json.NewEncoder(w).Encode(map[string]any{
		"summary":     summary,
		"items":       items,
		"page":        page,
		"size":        size,
		"days":        days,
		"topAccounts": topAccounts,
	})
}

// roiAccounts aggregates ROI by account_id from OfferDailyKPI joined with OfferAccountMap.
// GET /api/v1/console/roi/accounts?days=30&minRosc=0&q=123&page=1&size=50
func (h *Handler) roiAccounts(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	ctx := r.Context()
	days := 30
	if v := strings.TrimSpace(r.URL.Query().Get("days")); v != "" {
		if n, e := strconv.Atoi(v); e == nil && n > 0 && n <= 365 {
			days = n
		}
	}
	minRosc := 0.0
	if v := strings.TrimSpace(r.URL.Query().Get("minRosc")); v != "" {
		if f, e := strconv.ParseFloat(v, 64); e == nil && f >= 0 {
			minRosc = f
		}
	}
	q := strings.TrimSpace(r.URL.Query().Get("q")) // filter account_id contains
	page, size := 1, 50
	if v := strings.TrimSpace(r.URL.Query().Get("page")); v != "" {
		if n, e := strconv.Atoi(v); e == nil && n > 0 {
			page = n
		}
	}
	if v := strings.TrimSpace(r.URL.Query().Get("size")); v != "" {
		if n, e := strconv.Atoi(v); e == nil && n > 0 && n <= 500 {
			size = n
		}
	}
	offset := (page - 1) * size

	// Summary by accounts
	var sumSpend, sumRev float64
	err := h.DB.QueryRow(ctx, `
        SELECT COALESCE(SUM(k.spend),0), COALESCE(SUM(k.revenue),0)
        FROM "OfferDailyKPI" k JOIN "OfferAccountMap" m ON m.offer_id = k.offer_id
        WHERE k.date >= CURRENT_DATE - ($1::int - 1)
    `, days).Scan(&sumSpend, &sumRev)
	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "INTERNAL", "summary query failed", map[string]string{"error": err.Error()})
		return
	}
	summary := map[string]any{"spend": round2(sumSpend), "revenue": round2(sumRev), "rosc": func() float64 {
		if sumSpend > 0 {
			return round2(sumRev / sumSpend)
		}
		return 0
	}()}

	// Items per account
	filter := "%"
	if q != "" {
		filter = "%" + strings.ToLower(q) + "%"
	}
	rows, err := h.DB.Query(ctx, `
        SELECT m.account_id,
               COALESCE(SUM(k.spend),0) AS spend,
               COALESCE(SUM(k.revenue),0) AS revenue
        FROM "OfferDailyKPI" k
        JOIN "OfferAccountMap" m ON m.offer_id = k.offer_id
        WHERE k.date >= CURRENT_DATE - ($1::int - 1)
          AND ( $2 = '%' OR LOWER(m.account_id) LIKE $2 )
        GROUP BY m.account_id
        HAVING (CASE WHEN COALESCE(SUM(k.spend),0) > 0 THEN COALESCE(SUM(k.revenue),0)/COALESCE(SUM(k.spend),0) ELSE 0 END) >= $3
        ORDER BY COALESCE(SUM(k.revenue),0) DESC
        LIMIT $4 OFFSET $5
    `, days, filter, minRosc, size, offset)
	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "INTERNAL", "items query failed", map[string]string{"error": err.Error()})
		return
	}
	defer rows.Close()
	type rec struct {
		AccountID            string
		Spend, Revenue, ROSC float64
	}
	items := []rec{}
	for rows.Next() {
		var it rec
		if err := rows.Scan(&it.AccountID, &it.Spend, &it.Revenue); err != nil {
			continue
		}
		if it.Spend > 0 {
			it.ROSC = round2(it.Revenue / it.Spend)
		} else {
			it.ROSC = 0
		}
		it.Spend = round2(it.Spend)
		it.Revenue = round2(it.Revenue)
		items = append(items, it)
	}
	w.Header().Set("Content-Type", "application/json")
	_ = json.NewEncoder(w).Encode(map[string]any{"summary": summary, "items": items, "page": page, "size": size, "days": days})
}

// adscenterExecSummary aggregates Adscenter bulk execution outcomes from DB.
// GET /api/v1/console/adscenter/executions/summary?days=7&daily=1
// Returns: { operationsCompleted, execOk, execError, successRate, deadlettersPending, deadlettersFailed, daily: [{date, ok, error}] }
func (h *Handler) adscenterExecSummary(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	days := 7
	if v := strings.TrimSpace(r.URL.Query().Get("days")); v != "" {
		if n, e := strconv.Atoi(v); e == nil && n > 0 && n <= 90 {
			days = n
		}
	}
	wantDaily := strings.TrimSpace(r.URL.Query().Get("daily")) == "1"
	// operations completed
	var opsCompleted int64
	if err := h.DB.QueryRow(r.Context(), `SELECT COUNT(1) FROM "BulkActionOperation" WHERE status='completed' AND updated_at >= NOW() - ($1::text||' days')::interval`, days).Scan(&opsCompleted); err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "INTERNAL", "query operations failed", map[string]string{"error": err.Error()})
		return
	}
	// exec ok/error
	var okCnt, errCnt int64
	rows, err := h.DB.Query(r.Context(), `
        SELECT (snapshot->>'status') AS st, COUNT(1)
        FROM "BulkActionAudit"
        WHERE kind='exec' AND created_at >= NOW() - ($1::text||' days')::interval
        GROUP BY st`, days)
	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "INTERNAL", "query exec failed", map[string]string{"error": err.Error()})
		return
	}
	for rows.Next() {
		var st string
		var c int64
		if err := rows.Scan(&st, &c); err == nil {
			if strings.EqualFold(st, "ok") {
				okCnt += c
			} else if strings.EqualFold(st, "error") {
				errCnt += c
			}
		}
	}
	rows.Close()
	// deadletters
	var dlPending, dlFailed int64
	_ = h.DB.QueryRow(r.Context(), `SELECT COUNT(1) FROM "BulkActionDeadLetter" WHERE status='pending'`).Scan(&dlPending)
	_ = h.DB.QueryRow(r.Context(), `SELECT COUNT(1) FROM "BulkActionDeadLetter" WHERE status='failed'`).Scan(&dlFailed)
	// daily breakdown (optional)
	daily := []map[string]any{}
	if wantDaily {
		r2, err := h.DB.Query(r.Context(), `
            SELECT to_char(created_at::date,'YYYY-MM-DD') AS d, (snapshot->>'status') AS st, COUNT(1)
            FROM "BulkActionAudit"
            WHERE kind='exec' AND created_at >= NOW() - ($1::text||' days')::interval
            GROUP BY d, st ORDER BY d ASC`, days)
		if err == nil {
			tmp := map[string]struct{ ok, er int64 }{}
			for r2.Next() {
				var d, st string
				var c int64
				if r2.Scan(&d, &st, &c) != nil {
					continue
				}
				t := tmp[d]
				if strings.EqualFold(st, "ok") {
					t.ok += c
				} else if strings.EqualFold(st, "error") {
					t.er += c
				}
				tmp[d] = t
			}
			r2.Close()
			// stable order
			keys := make([]string, 0, len(tmp))
			for k := range tmp {
				keys = append(keys, k)
			}
			sort.Strings(keys)
			for _, k := range keys {
				v := tmp[k]
				daily = append(daily, map[string]any{"date": k, "ok": v.ok, "error": v.er})
			}
		}
	}
	rate := 0.0
	if okCnt+errCnt > 0 {
		rate = float64(okCnt) / float64(okCnt+errCnt)
	}
	out := map[string]any{
		"operationsCompleted": opsCompleted,
		"execOk":              okCnt,
		"execError":           errCnt,
		"successRate":         rate,
		"deadlettersPending":  dlPending,
		"deadlettersFailed":   dlFailed,
		"updatedAt":           time.Now().UTC().Format(time.RFC3339),
	}
	if wantDaily {
		out["daily"] = daily
	}
	w.Header().Set("Content-Type", "application/json")
	_ = json.NewEncoder(w).Encode(out)
}

// getSLO fetches /metrics from configured services and computes rough P95 and error rate.
// Env vars: *_URL (base) for siterank/billing/batchopen/adscenter/offer/notifications
func (h *Handler) getSLO(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	// caching
	if out, ok := getSLOCache(); ok && strings.TrimSpace(r.URL.Query().Get("force")) != "1" {
		w.Header().Set("Content-Type", "application/json")
		_ = json.NewEncoder(w).Encode(out)
		return
	}
	type serviceCfg struct{ name, url string }
	cfgs := []serviceCfg{
		{"siterank", strings.TrimRight(os.Getenv("SITERANK_URL"), "/")},
		{"billing", strings.TrimRight(os.Getenv("BILLING_URL"), "/")},
		{"batchopen", strings.TrimRight(os.Getenv("BATCHOPEN_URL"), "/")},
		{"adscenter", strings.TrimRight(os.Getenv("ADSCENTER_URL"), "/")},
		{"offer", strings.TrimRight(os.Getenv("OFFER_URL"), "/")},
		{"notifications", strings.TrimRight(os.Getenv("NOTIFICATIONS_URL"), "/")},
	}
	type slo struct {
		P95       float64            `json:"p95"`
		Total     int64              `json:"total"`
		ErrorRate float64            `json:"errorRate"`
		Notes     map[string]float64 `json:"notes,omitempty"`
	}
	out := map[string]slo{}
	for _, c := range cfgs {
		if c.url == "" {
			continue
		}
		ctx, cancel := context.WithTimeout(r.Context(), 1500*time.Millisecond)
		req, _ := http.NewRequestWithContext(ctx, http.MethodGet, c.url+"/metrics", nil)
		resp, err := httpx.New(1500 * time.Millisecond).DoRaw(req)
		cancel()
		if err != nil || resp == nil || resp.StatusCode != 200 {
			continue
		}
		b, _ := io.ReadAll(io.LimitReader(resp.Body, 1<<20))
		_ = resp.Body.Close()
		p95, total, errRate, notes := computeFromMetrics(string(b), c.name)
		out[c.name] = slo{P95: p95, Total: total, ErrorRate: errRate, Notes: notes}
	}
	res := map[string]any{"services": out, "updatedAt": time.Now().UTC().Format(time.RFC3339)}
	setSLOCache(res)
	w.Header().Set("Content-Type", "application/json")
	_ = json.NewEncoder(w).Encode(res)
}

// --- SLO cache ---
var sloCacheMu sync.RWMutex
var sloCache map[string]any
var sloCacheAt time.Time

const sloCacheTTL = 60 * time.Second

func getSLOCache() (map[string]any, bool) {
	sloCacheMu.RLock()
	defer sloCacheMu.RUnlock()
	if sloCache != nil && time.Since(sloCacheAt) < sloCacheTTL {
		// shallow copy to avoid mutation
		out := map[string]any{}
		for k, v := range sloCache {
			out[k] = v
		}
		return out, true
	}
	return nil, false
}
func setSLOCache(m map[string]any) {
	sloCacheMu.Lock()
	defer sloCacheMu.Unlock()
	sloCache = m
	sloCacheAt = time.Now()
}

// limitsPolicy supports GET (read current policy JSON) and PUT (update policy by creating a new secret version).
// Env: ADSCENTER_LIMITS_SECRET = projects/<pid>/secrets/<name>/versions/latest
func (h *Handler) limitsPolicy(w http.ResponseWriter, r *http.Request) {
	name := strings.TrimSpace(os.Getenv("ADSCENTER_LIMITS_SECRET"))
	if name == "" {
		errors.Write(w, r, http.StatusBadRequest, "SERVER_NOT_CONFIGURED", "ADSCENTER_LIMITS_SECRET not set", nil)
		return
	}
	ctx := r.Context()
	switch r.Method {
	case http.MethodGet:
		// read latest
		cli, err := secretmanager.NewClient(ctx)
		if err != nil {
			errors.Write(w, r, http.StatusInternalServerError, "SECRET_CLIENT", err.Error(), nil)
			return
		}
		defer cli.Close()
		res, err := cli.AccessSecretVersion(ctx, &secretmanagerpb.AccessSecretVersionRequest{Name: name})
		if err != nil {
			errors.Write(w, r, http.StatusInternalServerError, "SECRET_ACCESS", err.Error(), nil)
			return
		}
		// try JSON parse; if失败则以 text 形式返回
		var js map[string]any
		b := res.Payload.GetData()
		if json.Unmarshal(b, &js) == nil {
			_ = json.NewEncoder(w).Encode(map[string]any{"policy": js, "name": name})
			return
		}
		_ = json.NewEncoder(w).Encode(map[string]any{"policyText": string(b), "name": name})
	case http.MethodPut:
		// body: { policy: <object> } 或 { policyText: <string> }
		var body struct {
			Policy     any    `json:"policy"`
			PolicyText string `json:"policyText"`
		}
		if err := json.NewDecoder(r.Body).Decode(&body); err != nil {
			errors.Write(w, r, http.StatusBadRequest, "INVALID_ARGUMENT", "invalid json", nil)
			return
		}
		var payload []byte
		if body.Policy != nil {
			if b, err := json.Marshal(body.Policy); err == nil {
				payload = b
			}
		}
		if len(payload) == 0 && strings.TrimSpace(body.PolicyText) != "" {
			payload = []byte(body.PolicyText)
		}
		if len(payload) == 0 {
			errors.Write(w, r, http.StatusBadRequest, "INVALID_ARGUMENT", "missing policy", nil)
			return
		}
		// parent from versioned name: drop '/versions/...'
		parent := name
		if i := strings.LastIndex(parent, "/versions/"); i > 0 {
			parent = parent[:i]
		}
		cli, err := secretmanager.NewClient(ctx)
		if err != nil {
			errors.Write(w, r, http.StatusInternalServerError, "SECRET_CLIENT", err.Error(), nil)
			return
		}
		defer cli.Close()
		res, err := cli.AddSecretVersion(ctx, &secretmanagerpb.AddSecretVersionRequest{Parent: parent, Payload: &secretmanagerpb.SecretPayload{Data: payload}})
		if err != nil {
			errors.Write(w, r, http.StatusInternalServerError, "SECRET_ADD_VERSION", err.Error(), nil)
			return
		}
		_ = json.NewEncoder(w).Encode(map[string]any{"version": res.GetName()})
	default:
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
	}
}

// getEvents returns recent events from event_store with optional filters.
// GET /api/v1/console/events?eventName=&aggregateType=&aggregateId=&sinceHours=168&limit=100&offset=0
func (h *Handler) getEvents(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	q := r.URL.Query()
	eventName := strings.TrimSpace(q.Get("eventName"))
	aggType := strings.TrimSpace(q.Get("aggregateType"))
	aggId := strings.TrimSpace(q.Get("aggregateId"))
	sinceHours := 168
	if v := strings.TrimSpace(q.Get("sinceHours")); v != "" {
		if n, err := strconv.Atoi(v); err == nil && n > 0 && n <= (90*24) {
			sinceHours = n
		}
	}
	limit := 100
	if v := strings.TrimSpace(q.Get("limit")); v != "" {
		if n, err := strconv.Atoi(v); err == nil && n > 0 && n <= 500 {
			limit = n
		}
	}
	offset := 0
	if v := strings.TrimSpace(q.Get("offset")); v != "" {
		if n, err := strconv.Atoi(v); err == nil && n >= 0 {
			offset = n
		}
	}

	where := []string{"occurred_at > NOW() - ($1 || ' hours')::interval"}
	args := []any{sinceHours}
	argi := 2
	if eventName != "" {
		where = append(where, "event_name = $"+strconv.Itoa(argi))
		args = append(args, eventName)
		argi++
	}
	if aggType != "" {
		where = append(where, "aggregate_type = $"+strconv.Itoa(argi))
		args = append(args, aggType)
		argi++
	}
	if aggId != "" {
		where = append(where, "aggregate_id = $"+strconv.Itoa(argi))
		args = append(args, aggId)
		argi++
	}
	sqlStr := "SELECT id, event_id, event_name, aggregate_type, aggregate_id, occurred_at, payload::text FROM event_store WHERE " + strings.Join(where, " AND ") + " ORDER BY occurred_at DESC LIMIT $" + strconv.Itoa(argi) + " OFFSET $" + strconv.Itoa(argi+1)
	args = append(args, limit, offset)
	rows, err := h.DB.Query(r.Context(), sqlStr, args...)
	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "QUERY_FAILED", "query failed", map[string]string{"error": err.Error()})
		return
	}
	defer rows.Close()
	type item struct {
		ID            int64  `json:"id"`
		EventID       string `json:"eventId"`
		EventName     string `json:"eventName"`
		AggregateType string `json:"aggregateType"`
		AggregateID   string `json:"aggregateId"`
		OccurredAt    string `json:"occurredAt"`
		Payload       string `json:"payload"`
	}
	out := []item{}
	for rows.Next() {
		var it item
		var t time.Time
		if err := rows.Scan(&it.ID, &it.EventID, &it.EventName, &it.AggregateType, &it.AggregateID, &t, &it.Payload); err == nil {
			it.OccurredAt = t.UTC().Format(time.RFC3339)
			out = append(out, it)
		}
	}
	_ = json.NewEncoder(w).Encode(map[string]any{"items": out})
}

// getEventByID returns a single event by numeric id.
// GET /api/v1/console/events/{id}
func (h *Handler) getEventByID(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	path := strings.TrimPrefix(r.URL.Path, "/api/v1/console/events/")
	id := strings.TrimSpace(path)
	if id == "" {
		errors.Write(w, r, http.StatusBadRequest, "INVALID_ARGUMENT", "id required", nil)
		return
	}
	row := h.DB.QueryRow(r.Context(), `SELECT id, event_id, event_name, aggregate_type, aggregate_id, occurred_at, payload::text, metadata::text FROM event_store WHERE id=$1`, id)
	var it struct {
		ID            int64  `json:"id"`
		EventID       string `json:"eventId"`
		EventName     string `json:"eventName"`
		AggregateType string `json:"aggregateType"`
		AggregateID   string `json:"aggregateId"`
		OccurredAt    string `json:"occurredAt"`
		Payload       string `json:"payload"`
		Metadata      string `json:"metadata"`
	}
	var t time.Time
	if err := row.Scan(&it.ID, &it.EventID, &it.EventName, &it.AggregateType, &it.AggregateID, &t, &it.Payload, &it.Metadata); err != nil {
		errors.Write(w, r, http.StatusNotFound, "NOT_FOUND", "event not found", nil)
		return
	}
	it.OccurredAt = t.UTC().Format(time.RFC3339)
	_ = json.NewEncoder(w).Encode(it)
}

// replayPlan previews events to replay from event_store based on filters.
// GET /api/v1/console/events/replay/plan?eventName=&sinceHours=24&limit=100
func (h *Handler) replayPlan(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	q := r.URL.Query()
	eventName := strings.TrimSpace(q.Get("eventName"))
	sinceHours := 24
	if v := strings.TrimSpace(q.Get("sinceHours")); v != "" {
		if n, err := strconv.Atoi(v); err == nil && n > 0 && n <= (90*24) {
			sinceHours = n
		}
	}
	limit := 100
	if v := strings.TrimSpace(q.Get("limit")); v != "" {
		if n, err := strconv.Atoi(v); err == nil && n > 0 && n <= 1000 {
			limit = n
		}
	}
	where := []string{"occurred_at > NOW() - ($1 || ' hours')::interval"}
	args := []any{sinceHours}
	argi := 2
	if eventName != "" {
		where = append(where, "event_name=$"+strconv.Itoa(argi))
		args = append(args, eventName)
		argi++
	}
	sqlStr := "SELECT id, event_id, event_name, aggregate_type, aggregate_id, occurred_at FROM event_store WHERE " + strings.Join(where, " AND ") + " ORDER BY occurred_at ASC LIMIT $" + strconv.Itoa(argi)
	args = append(args, limit)
	rows, err := h.DB.Query(r.Context(), sqlStr, args...)
	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "QUERY_FAILED", "query failed", map[string]string{"error": err.Error()})
		return
	}
	defer rows.Close()
	type item struct {
		ID            int64  `json:"id"`
		EventID       string `json:"eventId"`
		EventName     string `json:"eventName"`
		AggregateType string `json:"aggregateType"`
		AggregateID   string `json:"aggregateId"`
		OccurredAt    string `json:"occurredAt"`
	}
	out := []item{}
	for rows.Next() {
		var it item
		var t time.Time
		if err := rows.Scan(&it.ID, &it.EventID, &it.EventName, &it.AggregateType, &it.AggregateID, &t); err == nil {
			it.OccurredAt = t.UTC().Format(time.RFC3339)
			out = append(out, it)
		}
	}
	_ = json.NewEncoder(w).Encode(map[string]any{"items": out, "count": len(out)})
}

// replayExecute republishes events to the current Pub/Sub topic.
// POST /api/v1/console/events/replay { ids?: [int], sinceHours?: 24, limit?: 100 }
func (h *Handler) replayExecute(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	var body struct {
		IDs        []int64 `json:"ids"`
		SinceHours *int    `json:"sinceHours"`
		Limit      *int    `json:"limit"`
	}
	if err := json.NewDecoder(r.Body).Decode(&body); err != nil {
		errors.Write(w, r, http.StatusBadRequest, "INVALID_ARGUMENT", "invalid json", nil)
		return
	}
	ctx := r.Context()
	// Build selection
	var rows pgx.Rows
	var err error
	if len(body.IDs) > 0 {
		// replay specific ids
		// build IN clause
		place := make([]string, 0, len(body.IDs))
		args := make([]any, 0, len(body.IDs))
		for i, id := range body.IDs {
			place = append(place, "$"+strconv.Itoa(i+1))
			args = append(args, id)
		}
		sqlStr := "SELECT id, event_name, aggregate_id, payload::text FROM event_store WHERE id IN (" + strings.Join(place, ",") + ") ORDER BY id ASC"
		rows, err = h.DB.Query(ctx, sqlStr, args...)
	} else {
		since := 24
		if body.SinceHours != nil {
			since = *body.SinceHours
		}
		limit := 100
		if body.Limit != nil {
			limit = *body.Limit
		}
		rows, err = h.DB.Query(ctx, `SELECT id, event_name, aggregate_id, payload::text FROM event_store WHERE occurred_at > NOW() - ($1 || ' hours')::interval ORDER BY occurred_at ASC LIMIT $2`, since, limit)
	}
	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "QUERY_FAILED", "query failed", map[string]string{"error": err.Error()})
		return
	}
	defer rows.Close()
	// Publisher (pkg/events)
	pub, perr := ev.NewPublisher(ctx)
	if perr != nil {
		errors.Write(w, r, http.StatusInternalServerError, "PUBLISHER_INIT", perr.Error(), nil)
		return
	}
	defer pub.Close()
	type item struct {
		ID          int64
		Name, AggID string
		Payload     string
	}
	list := []item{}
	for rows.Next() {
		var it item
		if err := rows.Scan(&it.ID, &it.Name, &it.AggID, &it.Payload); err == nil {
			list = append(list, it)
		}
	}
	published := 0
	failed := 0
	for _, it := range list {
		var data any
		if strings.TrimSpace(it.Payload) != "" {
			json.Unmarshal([]byte(it.Payload), &data)
		}
		if err := pub.Publish(ctx, it.Name, data, ev.WithSource("replay"), ev.WithSubject(it.AggID)); err != nil {
			failed++
		} else {
			published++
		}
	}
	_ = json.NewEncoder(w).Encode(map[string]any{"requested": len(list), "published": published, "failed": failed})
}

// offerConsistency checks read-model Offer vs events OfferCreated, optional repair.
// GET /api/v1/console/consistency/offers?repair=false&limit=100
func (h *Handler) offerConsistency(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet && r.Method != http.MethodPost {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	q := r.URL.Query()
	limit := 200
	if v := strings.TrimSpace(q.Get("limit")); v != "" {
		if n, err := strconv.Atoi(v); err == nil && n > 0 && n <= 1000 {
			limit = n
		}
	}
	repair := strings.EqualFold(strings.TrimSpace(q.Get("repair")), "true") || r.Method == http.MethodPost
	// Find OfferCreated events missing in Offer table
	rows, err := h.DB.Query(r.Context(), `
        SELECT e.aggregate_id, e.payload::text
        FROM event_store e
        LEFT JOIN "Offer" o ON o.id = e.aggregate_id
        WHERE e.event_name='OfferCreated' AND o.id IS NULL
        ORDER BY e.occurred_at ASC
        LIMIT $1`, limit)
	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "QUERY_FAILED", "query failed", map[string]string{"error": err.Error()})
		return
	}
	defer rows.Close()
	type miss struct {
		OfferID string `json:"offerId"`
		Payload string `json:"payload"`
	}
	missing := []miss{}
	for rows.Next() {
		var id, p string
		if err := rows.Scan(&id, &p); err == nil {
			missing = append(missing, miss{OfferID: id, Payload: p})
		}
	}
	repaired := 0
	if repair && len(missing) > 0 {
		tx, _ := h.DB.Begin(r.Context())
		for _, m := range missing {
			// try parse payload
			var obj map[string]any
			_ = json.Unmarshal([]byte(m.Payload), &obj)
			name, _ := obj["name"].(string)
			url, _ := obj["originalUrl"].(string)
			uid, _ := obj["userId"].(string)
			status, _ := obj["status"].(string)
			if strings.TrimSpace(status) == "" {
				status = "evaluating"
			}
			if strings.TrimSpace(uid) == "" {
				continue
			}
			_, err := tx.Exec(r.Context(), `
                INSERT INTO "Offer"(id, "userId", name, "originalUrl", status, created_at, updated_at)
                VALUES ($1,$2,COALESCE(NULLIF($3,''),'Offer'),COALESCE(NULLIF($4,''),'https://example.com'),'evaluating',NOW(),NOW())
                ON CONFLICT (id) DO NOTHING
            `, m.OfferID, uid, name, url)
			if err == nil {
				repaired++
			}
		}
		_ = tx.Commit(r.Context())
	}
	_ = json.NewEncoder(w).Encode(map[string]any{"missing": missing, "repaired": repaired})
}

