// adsSyncMetrics: GET /api/v1/console/adscenter/sync/metrics?userId=&limit=
// Returns recent AdsAccountMetrics rows for specified user (or recent users if empty)
func (h *Handler) adsSyncMetrics(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	userID := strings.TrimSpace(r.URL.Query().Get("userId"))
	limit := 50
	if v := strings.TrimSpace(r.URL.Query().Get("limit")); v != "" {
		if n, e := strconv.Atoi(v); e == nil && n > 0 && n <= 200 {
			limit = n
		}
	}
	// Ensure table; tolerate absence
	_, _ = h.DB.Exec(r.Context(), `CREATE TABLE IF NOT EXISTS "AdsAccountMetrics"(user_id TEXT NOT NULL, customer_id TEXT NOT NULL, campaigns INT NOT NULL DEFAULT 0, updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(), PRIMARY KEY(user_id, customer_id))`)
	type item struct {
		UserID, CustomerID string
		Campaigns          int
		UpdatedAt          string
	}
	items := []item{}
	if userID != "" {
		rows, err := h.DB.Query(r.Context(), `SELECT user_id, customer_id, campaigns, updated_at FROM "AdsAccountMetrics" WHERE user_id=$1 ORDER BY updated_at DESC LIMIT $2`, userID, limit)
		if err == nil {
			defer rows.Close()
			for rows.Next() {
				var it item
				var t time.Time
				if rows.Scan(&it.UserID, &it.CustomerID, &it.Campaigns, &t) == nil {
					it.UpdatedAt = t.UTC().Format(time.RFC3339)
					items = append(items, it)
				}
			}
		}
	} else {
		rows, err := h.DB.Query(r.Context(), `SELECT user_id, customer_id, campaigns, updated_at FROM "AdsAccountMetrics" ORDER BY updated_at DESC LIMIT $1`, limit)
		if err == nil {
			defer rows.Close()
			for rows.Next() {
				var it item
				var t time.Time
				if rows.Scan(&it.UserID, &it.CustomerID, &it.Campaigns, &t) == nil {
					it.UpdatedAt = t.UTC().Format(time.RFC3339)
					items = append(items, it)
				}
			}
		}
	}
	_ = json.NewEncoder(w).Encode(map[string]any{"items": items})
}

// adsSyncRun: POST /api/v1/console/adscenter/sync/run { limit?, users? }
// Proxies to Adscenter /api/v1/adscenter/sync/tick in system mode
func (h *Handler) adsSyncRun(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	var body struct {
		Limit int `json:"limit"`
		Users int `json:"users"`
	}
	_ = json.NewDecoder(r.Body).Decode(&body)
	if body.Limit <= 0 {
		body.Limit = 5
	}
	if body.Users <= 0 {
		body.Users = 3
	}
	base := strings.TrimRight(os.Getenv("ADSCENTER_URL"), "/")
	if base == "" {
		errors.Write(w, r, http.StatusInternalServerError, "SERVER_NOT_CONFIGURED", "ADSCENTER_URL not set", nil)
		return
	}
	cli := httpx.New(6 * time.Second)
	hdr := map[string]string{"X-User-Id": "scheduler", "Accept": "application/json"}
	url := fmt.Sprintf("%s/api/v1/adscenter/sync/tick?limit=%d&mode=system&users=%d", base, body.Limit, body.Users)
	var out map[string]any
	if err := cli.DoJSON(r.Context(), http.MethodPost, url, map[string]any{}, hdr, 1, &out); err != nil {
		errors.Write(w, r, http.StatusBadGateway, "UPSTREAM", err.Error(), nil)
		return
	}
	_ = json.NewEncoder(w).Encode(out)
}

// --- Offer KPI DLQ admin ---

// List Offer KPI deadletters (direct DB read)
// GET /api/v1/console/offers/kpi/deadletters?limit=50
func (h *Handler) offerKpiDeadLetters(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		errors.Write(w, r, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "Method not allowed", nil)
		return
	}
	lim := 50
	if v := strings.TrimSpace(r.URL.Query().Get("limit")); v != "" {
		if n, e := strconv.Atoi(v); e == nil && n > 0 && n <= 500 {
			lim = n
		}
	}
	rows, err := h.DB.Query(r.Context(), `SELECT id,user_id,offer_id,date,reason,payload::text,retry_count,last_error,status,created_at,updated_at FROM "OfferKpiDeadLetter" WHERE status<>'resolved' ORDER BY created_at DESC LIMIT $1`, lim)
	if err != nil {
		errors.Write(w, r, http.StatusInternalServerError, "INTERNAL", "query failed", map[string]string{"error": err.Error()})
		return
	}
	defer rows.Close()
	type item struct {
		ID         int64  `json:"id"`
		UserID     string `json:"userId"`
		OfferID    string `json:"offerId"`
		Date       string `json:"date"`
		Reason     string `json:"reason"`
		Payload    string `json:"payload"`
		RetryCount int    `json:"retryCount"`
		LastError  string `json:"lastError"`
		Status     string `json:"status"`
		CreatedAt  string `json:"createdAt"`
		UpdatedAt  string `json:"updatedAt"`
	}
	var items []item
	for rows.Next() {
		var it item
		var d, ca, ua time.Time
		if err := rows.Scan(&it.ID, &it.UserID, &it.OfferID, &d, &it.Reason, &it.Payload, &it.RetryCount, &it.LastError, &it.Status, &ca, &ua); err != nil {
			errors.Write(w, r, http.StatusInternalServerError, "INTERNAL", "scan failed", nil)
			return
		}
		it.Date = d.Format("2006-01-02")
		it.CreatedAt = ca.Format(time.RFC3339)
		it.UpdatedAt = ua.Format(time.RFC3339)
		items = append(items, it)
	}
	_ = json.NewEncoder(w).Encode(map[string]any{"items": items})
}

